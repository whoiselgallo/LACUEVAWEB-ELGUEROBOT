# ═════════════════════════════════════════════════════════════════════════════════
# ENTORNO
# ═════════════════════════════════════════════════════════════════════════════════
APP_ENV=production
APP_DEBUG=false

# ═════════════════════════════════════════════════════════════════════════════════
